// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enum para el rol del usuario ───────────────────────────
enum Role {
  ADMIN
  ORGANIZER
}

// ─── Usuario ─────────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ORGANIZER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuario")
}

// ─── Enum para el estado del corte ───────────────────────────
enum EstadoCorte {
  ACTIVO
  INACTIVO
}

// ─── Parámetros de corte ─────────────────────────────────────
model ParametrosCorte {
  id            Int         @id @default(autoincrement())
  fechaCorte    DateTime    @db.Date
  estado        EstadoCorte @default(ACTIVO)
  creadoPor     Int
  nombreUsuario String
  creadoEn      DateTime    @default(now())

  deudas DeudaBanco[]

  @@map("parametros_corte")
}

// ─── Deuda consolidada por cliente (1 fila por factura) ──────
// Guarda cada factura individual con todos sus componentes calculados
model DeudaBanco {
  id          Int             @id @default(autoincrement())
  idParametro Int
  parametro   ParametrosCorte @relation(fields: [idParametro], references: [id], onDelete: Cascade)

  // Identificación de la factura en el SIIM
  idFacturaSiim Int
  id_modulo     Int

  // Datos del cliente
  tipo          String @default("CO")
  contrapartida String
  moneda        String @default("USD")
  formaCobro    String @default("REC")
  referencia    String @default("")
  tipoId        String
  numeroId      String
  nombreCliente String
  idCliente     String

  // Montos por factura (calculados y redondeados individualmente)
  montoNominal   Decimal @db.Decimal(10, 2)
  montoInteres   Decimal @default(0) @db.Decimal(10, 2)
  montoMora      Decimal @default(0) @db.Decimal(10, 2)
  montoDescuento Decimal @default(0) @db.Decimal(10, 2) // siempre negativo
  montoRecargo   Decimal @default(0) @db.Decimal(10, 2) // siempre positivo
  totalFactura   Decimal @db.Decimal(10, 2)

  // --- NUEVOS CAMPOS: componentes originales del SQL (para auditoría y cálculos futuros) ---
  impuestoPredial Decimal @default(0) @db.Decimal(10, 2)
  exoneracion     Decimal @default(0) @db.Decimal(10, 2)
  cem             Decimal @default(0) @db.Decimal(10, 2)  // solo rural, 0 para urbano/agua

  @@map("deuda_banco")
}